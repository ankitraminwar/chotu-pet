{
  "name": "chotu-pet",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/build.mjs",
    "build:popup": "vite build",
    "build:scripts": "node scripts/build.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "sounds:download": "node scripts/download-sounds.mjs",
    "sounds:check": "node scripts/check-sounds.mjs",
    "type-check": "tsc -b",
    "preflight": "npm run type-check && npm run lint && npm run build",
    "package": "npm run build && cd dist && zip -r ../releases/chotu-pet-v$(node -p \"require('../package.json').version\").zip . && cd ..",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/chrome": "^0.1.38",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
